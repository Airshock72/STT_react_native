{
  "expo": {
    "name": "STT React Native",
    "slug": "stt-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBFBFB"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBFBFB"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "$(PRODUCT_NAME)-ს სჭირდება მიკროფონზე წვდომა ხმის ჩასაწერად.",
          "speechRecognitionPermission": "$(PRODUCT_NAME)-ს სჭირდება წვდომა მეტყველების ამოსაცნობად და ტექსტად გადასაყვანად.",
          "androidSpeechServicePackages": [
            "com.google.android.as",
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts"
          ]
        }
      ]
    ]
  }
}
